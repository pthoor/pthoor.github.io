---
layout: null
---
[{% for post in site.posts %}{"url":{{ post.url | relative_url | jsonify }},"title":{{ post.title | jsonify }},"date":{{ post.date | date: "%B %-d, %Y" | jsonify }},"tags":{{ post.tags | jsonify }},"excerpt":{{ post.excerpt | strip_html | truncatewords: 40 | jsonify }},"content":{{ post.content | strip_html | normalize_whitespace | truncatewords: 300 | jsonify }}}{% unless forloop.last %},{% endunless %}{% endfor %}]
