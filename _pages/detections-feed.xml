---
layout: null
permalink: /detections/feed.xml
---
<?xml version="1.0" encoding="UTF-8"?>
<feed xmlns="http://www.w3.org/2005/Atom">
  <title>{{ site.title | xml_escape }} — Detection Rules</title>
  <subtitle>KQL hunting queries and detection rules for Microsoft Sentinel, Defender XDR, and Defender for Cloud</subtitle>
  <link href="{{ '/detections/feed.xml' | absolute_url }}" rel="self" type="application/atom+xml"/>
  <link href="{{ '/detections/' | absolute_url }}" rel="alternate" type="text/html"/>
  <id>{{ '/detections/' | absolute_url }}</id>
  <updated>{{ site.time | date_to_xmlschema }}</updated>
  <author>
    <name>{{ site.author.name | xml_escape }}</name>
  </author>
  {% assign dets = site.data.detections.detections %}
  {% for det in dets %}
  <entry>
    <title>{{ det.name | xml_escape }}</title>
    <link href="{{ '/detections/#det-' | append: det.slug | absolute_url }}" rel="alternate" type="text/html"/>
    <id>{{ '/detections/#det-' | append: det.slug | absolute_url }}</id>
    <updated>{{ site.time | date_to_xmlschema }}</updated>
    <summary>{{ det.description | xml_escape }}</summary>
    <category term="{{ det.product | xml_escape }}" label="Product: {{ det.product | xml_escape }}"/>
    {% for t in det.tactics %}
    <category term="{{ t | xml_escape }}" label="Tactic: {{ t | xml_escape }}"/>
    {% endfor %}
    {% for t in det.techniques %}
    <category term="{{ t | xml_escape }}" label="MITRE: {{ t | xml_escape }}"/>
    {% endfor %}
    {% for ds in det.data_sources %}
    <category term="{{ ds | xml_escape }}" label="Data Source: {{ ds | xml_escape }}"/>
    {% endfor %}
    {% for t in det.tags %}
    <category term="{{ t | xml_escape }}" label="{{ t | xml_escape }}"/>
    {% endfor %}
  </entry>
  {% endfor %}
</feed>
